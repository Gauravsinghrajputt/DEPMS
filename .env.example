# ─── App ───────────────────────────────────────────────
NODE_ENV=development
PORT=3000
FRONTEND_URL=http://localhost:5173

# ─── Database ──────────────────────────────────────────
DB_HOST=postgres
DB_PORT=5432
DB_NAME=depms
DB_USER=depms_user
DB_PASSWORD=change_me_in_production

# ─── Redis ─────────────────────────────────────────────
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=

# ─── JWT ───────────────────────────────────────────────
JWT_SECRET=super_secret_change_in_production_min_32_chars
JWT_EXPIRES_IN=8h
JWT_REFRESH_SECRET=refresh_secret_change_in_production
JWT_REFRESH_EXPIRES_IN=7d

# ─── Security ──────────────────────────────────────────
BCRYPT_ROUNDS=12
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=100
AUTH_RATE_LIMIT_MAX=10

# ─── File Storage (S3-compatible) ──────────────────────
STORAGE_PROVIDER=local        # local | s3 | azure
S3_BUCKET=depms-exports
S3_REGION=ap-south-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=

# ─── Email (SMTP) ──────────────────────────────────────
SMTP_HOST=smtp.mailtrap.io
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
EMAIL_FROM=noreply@company.com

# ─── Logging ───────────────────────────────────────────
LOG_LEVEL=info
